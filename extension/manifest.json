{
  "manifest_version": 3,
  "name": "Contxtly",
  "version": "1.0.0",
  "description": "Contextual translator",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Contxtly Settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["styles/content.css"]
    }
  ]
}
